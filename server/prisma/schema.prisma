generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  journalEntries JournalEntry[]
}

model Transaction {
  id        String   @id @default(uuid())
  amount    Float
  type      String   // deposit, withdrawal, profit, loss
  category  String
  date      DateTime
  notes     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JournalEntry {
  id           String   @id @default(uuid())
  date         DateTime @unique
  stakedAmount Float    // Amount you risked/put in
  profitAmount Float    // Amount you profited (0 if loss)
  lossAmount   Float    // Amount you lost (0 if profit)
  netResult    Float    // profitAmount - lossAmount (auto-calculated)
  notes        String?
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
